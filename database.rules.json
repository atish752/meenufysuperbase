{
  "rules": {
    "restaurantAccounts": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "restaurants": {
      "$restaurantId": {
        ".read": true,
        ".write": "auth != null && (auth.uid == $restaurantId || $restaurantId == 'admin-1')"
      }
    },
    "menuItems": {
      "$restaurantId": {
        ".read": true,
        ".write": "auth != null && (auth.uid == $restaurantId || $restaurantId == 'admin-1')"
      }
    },
    "categories": {
      "$restaurantId": {
        ".read": true,
        ".write": "auth != null && (auth.uid == $restaurantId || $restaurantId == 'admin-1')"
      }
    },
    "orders": {
      "$restaurantId": {
        ".read": true,
        ".write": true
      }
    },
    "customers": {
      "$restaurantId": {
        ".read": true,
        ".write": true
      }
    },
    "tables": {
      "$restaurantId": {
        ".read": true,
        ".write": true
      }
    },
    "reservations": {
      "$restaurantId": {
        ".read": true,
        ".write": true
      }
    },
    "coupons": {
      "$restaurantId": {
        ".read": true,
        ".write": true
      }
    },
    "waiterRequests": {
      "$restaurantId": {
        ".read": true,
        ".write": true
      }
    },
    "schedules": {
      "$restaurantId": {
        ".read": true,
        ".write": true
      }
    },
    "meenufy_config": {
      ".read": true,
      ".write": true
    },
    "geminiApiKeys": {
      ".read": true,
      ".write": true
    },
    "supportRequests": {
      ".read": true,
      ".write": true
    },
    "ownerFeedbacks": {
      ".read": true,
      ".write": true
    },
    "subscriptionCoupons": {
      ".read": true,
      ".write": true
    },
    "staffMembers": {
      ".read": true,
      ".write": true
    }
  }
}
